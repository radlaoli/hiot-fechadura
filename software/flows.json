    {
        "id": "33e315f3307864cc",
        "type": "function",
        "z": "9dac3a16c184f8e6",
        "name": "Query Cadastro",
        "func": "var dados = msg.payload;\nvar nomeLimpo = dados.nome.trim();\nvar tagLimpa = dados.tag.trim().toUpperCase();\n\nif (nomeLimpo === \"\" || tagLimpa === \"\") {\n    node.error(\"Campos obrigatorios vazios.\");\n    return null;\n}\n\nmsg.topic = \"INSERT INTO usuarios (nome) VALUES ('\" + nomeLimpo + \"'); \" +\n            \"SET @ultimo_id = LAST_INSERT_ID(); \" +\n            \"INSERT INTO permissoes_fechadura (tag_nfc, usuario_id) VALUES ('\" + tagLimpa + \"', @ultimo_id);\";\n\nreturn msg;",
