        "func": "let tag_lida = msg.payload.uid; \nmsg.topic = \"SELECT u.id, u.nome, p.ativo FROM usuarios u JOIN permissoes_fechadura p ON u.id = p.usuario_id WHERE p.tag_nfc = '\" + tag_lida + \"';\";\nreturn msg;",
