    {
        "id": "88ee6d5869cd0c32",
        "type": "function",
        "z": "9dac3a16c184f8e6",
        "name": "Processador de Segurança",
        "func": "var resultadoNFC = flow.get(\"status_nfc\") || \"bloqueado\";\n\nif (resultadoNFC === \"aprovado\") {\n    flow.set(\"status_nfc\", \"bloqueado\");\n    msg.topic = \"INSERT INTO historico_sistema (tipo_evento, tag_nfc, usuario_id, autorizado, descricao) VALUES ('ABERTURA_COMUM', NULL, NULL, NULL, 'Porta aberta apos autenticacao valida.');\";\n    msg.pushover_msg = \"Acesso confirmado.\";\n    return [msg, null]; \n} else {\n    msg.topic = \"INSERT INTO historico_sistema (tipo_evento, tag_nfc, usuario_id, autorizado, descricao) VALUES ('ARROMBAMENTO', NULL, NULL, NULL, 'Alerta: Abertura de porta sem autorizacao.');\";\n    msg.pushover_msg = \"Alerta de seguranca: Abertura nao autorizada detectada.\";\n    return [null, msg];\n}",
