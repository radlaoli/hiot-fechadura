    {
        "id": "517b14f707c0bbcb",
        "type": "function",
        "z": "9dac3a16c184f8e6",
        "name": "Liberação e Log",
        "func": "var usuario = msg.payload[0];\nmsg.usuario_id = usuario.id;\nmsg.autorizado = 1;\n\nflow.set(\"status_nfc\", \"aprovado\");\nmsg.payload = \"abrir\";\nmsg.query_historico = \"INSERT INTO historico_sistema (tipo_evento, tag_nfc, usuario_id, autorizado, descricao) VALUES ('NFC_AUTORIZADO', '\" + msg.tag + \"', \" + usuario.id + \", 1, 'Acesso liberado: \" + usuario.nome + \"');\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
